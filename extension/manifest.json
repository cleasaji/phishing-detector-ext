{
  "manifest_version": 3,
  "name": "Phishing Detector",
  "version": "1.0.0",
  "description": "Real-time phishing URL detection using ML scoring and blocklist lookup.",
  "permissions": [
    "tabs",
    "storage",
    "activeTab"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Phishing Detector"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
